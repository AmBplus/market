@model Web.Pages.AdminPanel.ID.Users.UserUpsertModel

<div id="formErrorBox" class="alert alert-danger d-none" role="alert"></div>

<form asp-page-handler="Edit" method="post" id="editUserForm">
    <input hidden asp-for="Id" />

    <div class="row">

        <div class="col-12 col-md-6 mb-3">
            <div class="input-group">
                <span class="input-group-text">نام کاربری</span>
                <input asp-for="UserName"
                       class="form-control"
                       autocomplete="off"
                       placeholder="نام کاربری" />
            </div>
            <span asp-validation-for="UserName" class="text-danger small"></span>
        </div>

        <div class="col-12 col-md-6 mb-3">
            <div class="input-group">
                <span class="input-group-text">ایمیل</span>
                <input asp-for="Email"
                       class="form-control"
                       autocomplete="off"
                       placeholder="ایمیل" />
            </div>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>
        <div>
            <select>
                <option value="1200">1200</option>
                <option value="1202">1202</option>
                <option value="1203">1203</option>
                <option value="1204">1204</option>
            </select>
        </div>
        @if (Model.Id == 0)
        {
            <div class="col-12 col-md-6 mb-3">
                <div class="input-group">
                    <span class="input-group-text">رمز عبور</span>
                    <input asp-for="Password"
                           type="password"
                           class="form-control"
                           autocomplete="new-password"
                           placeholder="رمز عبور" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
        }

        <div class="col-12 col-md-6 mb-3">
            <div class="input-group">
                <span class="input-group-text">موبایل</span>
                <input asp-for="Mobile"
                       class="form-control"
                       autocomplete="off"
                       placeholder="موبایل" />
            </div>
            <span asp-validation-for="Mobile" class="text-danger small"></span>
        </div>

        <div class="col-12 col-md-4 mb-3">
            <div class="input-group">
                <span class="input-group-text">نام</span>
                <input asp-for="FirstName"
                       class="form-control"
                       autocomplete="off"
                       placeholder="نام" />
            </div>
            <span asp-validation-for="FirstName" class="text-danger small"></span>
        </div>

        <div class="col-12 col-md-4 mb-3">
            <div class="input-group">
                <span class="input-group-text">نام خانوادگی</span>
                <input asp-for="LastName"
                       class="form-control"
                       autocomplete="off"
                       placeholder="نام خانوادگی" />
            </div>
            <span asp-validation-for="LastName" class="text-danger small"></span>
        </div>

        <div class="col-12 col-md-4 mb-3">
            <div class="input-group">
                <span class="input-group-text">نام پدر</span>
                <input asp-for="FatherName"
                       class="form-control"
                       autocomplete="off"
                       placeholder="نام پدر" />
            </div>
            <span asp-validation-for="FatherName" class="text-danger small"></span>
        </div>

        <div class="col-12 col-md-4 mb-3">
            <div class="input-group">
                <span class="input-group-text">کد ملی</span>
                <input asp-for="NationalId"
                       class="form-control"
                       autocomplete="off"
                       placeholder="کد ملی" />
            </div>
            <span asp-validation-for="NationalId" class="text-danger small"></span>
        </div>

        <div class="col-12 col-md-4 mb-3">
            <div class="input-group">
                <span class="input-group-text">پاسپورت</span>
                <input asp-for="PassportNumber"
                       class="form-control"
                       autocomplete="off"
                       placeholder="شماره پاسپورت" />
            </div>
            <span asp-validation-for="PassportNumber" class="text-danger small"></span>
        </div>

        <div class="col-12 col-md-4 mb-3">
            <div class="input-group">
                <span class="input-group-text">ملیت</span>
                <input asp-for="Nationality"
                       class="form-control"
                       autocomplete="off"
                       placeholder="ملیت" />
            </div>
            <span asp-validation-for="Nationality" class="text-danger small"></span>
        </div>

        <div class="col-12 col-md-6 mb-3">
            <div class="input-group">
                <span class="input-group-text">تاریخ تولد</span>
                <input asp-for="BirthDate"
                       type="text"

                       autocomplete="off"
                       data-jdp onchange="console.log" data-jdp-min-date="1300/01/01"
                       data-jdp-min-persian-digits="true" class="form-control changeserach dt-input amb-form-input"
                       placeholder="1370/01/01" />
            </div>
            <span asp-validation-for="BirthDate" class="text-danger small"></span>
        </div>

        <div class="col-12 mb-3">
            <div class="input-group">
                <span class="input-group-text">آدرس</span>
                <textarea asp-for="Address"
                          class="form-control"
                          rows="2"
                          placeholder="آدرس"></textarea>
            </div>
            <span asp-validation-for="Address" class="text-danger small"></span>
        </div>

        <div class="col-12 mb-3">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label class="form-check-label" asp-for="IsActive">فعال</label>
            </div>
        </div>

        <div class="col-12 d-flex justify-content-end">
            <button type="button" class="btn submit @(Model.Id == 0 ? "btn-success" : "btn-warning")">
                @(Model.Id == 0 ? "ایجاد کاربر" : "ذخیره تغییرات")
            </button>
        </div>

    </div>
</form>
