@using Framework.Resources
@{
    /// Version 4.0

    // نکته مهم
    // در همه شرایط کار نمی‌کند List استفاده از کلاس
    var pageErrors =
        TempData[key: Infrastructure.Messages.MessageType.PageError.ToString()] as
        System.Collections.Generic.IList<string>;
    TempData[key: Infrastructure.Messages.MessageType.PageError.ToString()] = null;
    var pageWarnings =
        TempData[key: Infrastructure.Messages.MessageType.PageWarning.ToString()] as
        System.Collections.Generic.IList<string>;
    TempData[key: Infrastructure.Messages.MessageType.PageWarning.ToString()] = null;

    var pageSuccesses =
        TempData[key: Infrastructure.Messages.MessageType.PageSuccess.ToString()] as
        System.Collections.Generic.IList<string>;
    TempData[key: Infrastructure.Messages.MessageType.PageSuccess.ToString()] = null;

    if ((pageErrors == null || pageErrors.Count == 0) &&
    (pageWarnings == null || pageWarnings.Count == 0) &&
    (pageSuccesses == null || pageSuccesses.Count == 0))
    {
        return;
    }
    TempData[key: Infrastructure.Messages.MessageType.PageError.ToString()] = null;
    TempData[key: Infrastructure.Messages.MessageType.PageWarning.ToString()] = null;
    TempData[key: Infrastructure.Messages.MessageType.PageSuccess.ToString()] = null;
    if (pageErrors != null && pageErrors.Count != 0)
	{
        <div class="alert alert-danger alert-dismissible shadow fade show text-right alert-message" style="border:#721C24 1.5px solid" role="alert">
            <div class="alert-heading">


                <div class="row">
                    <button type="button"
                            class="btn-close btn-close-black me-2 m-auto"
                            data-bs-dismiss="alert"
                            aria-label="&times;"
                           ></button>
                    <div class="row">
                        <p style="font-size:18px" class="mb-2 font-weight-light">
                            <b class="mx-1 mb-2 mt-1">
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-alert-octagon-filled" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M14.897 1a4 4 0 0 1 2.664 1.016l.165 .156l4.1 4.1a4 4 0 0 1 1.168 2.605l.006 .227v5.794a4 4 0 0 1 -1.016 2.664l-.156 .165l-4.1 4.1a4 4 0 0 1 -2.603 1.168l-.227 .006h-5.795a3.999 3.999 0 0 1 -2.664 -1.017l-.165 -.156l-4.1 -4.1a4 4 0 0 1 -1.168 -2.604l-.006 -.227v-5.794a4 4 0 0 1 1.016 -2.664l.156 -.165l4.1 -4.1a4 4 0 0 1 2.605 -1.168l.227 -.006h5.793zm-2.887 14l-.127 .007a1 1 0 0 0 0 1.986l.117 .007l.127 -.007a1 1 0 0 0 0 -1.986l-.117 -.007zm-.01 -8a1 1 0 0 0 -.993 .883l-.007 .117v4l.007 .117a1 1 0 0 0 1.986 0l.007 -.117v-4l-.007 -.117a1 1 0 0 0 -.993 -.883z" stroke-width="0" fill="currentColor" /></svg>
                                @Messages.Error !
                            </b>
                        </p>


                    </div>
                </div>

            </div>

            <ul class="mb-0">
        
                @foreach (var message in pageErrors)
				{
					<li>@(message)</li>
				}
			</ul>
            <button type="button"
                    class="btn-close btn-close-black me-2 m-auto"
                    data-bs-dismiss="alert"
                    aria-label="&times;"></button>
        </div>
	}

	if (pageWarnings != null && pageWarnings.Count != 0)
	{
     
        <div class="alert alert-warning alert-dismissible shadow fade show text-right alert-message " style="border:#eb9e34 1.5px solid" role="alert">
            <div class="alert-heading">


                <div class="row">
                    <button type="button"
                            class="btn-close btn-close me-2 m-auto"
                            data-bs-dismiss="alert"
                            aria-label="&times;"
                          ></button>
                    <div class="row">
                        <p style="font-size:18px" class="mb-2 font-weight-light">
                            <b class="mx-1 mb-2 mt-1">
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-alert-triangle-filled" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M12 1.67c.955 0 1.845 .467 2.39 1.247l.105 .16l8.114 13.548a2.914 2.914 0 0 1 -2.307 4.363l-.195 .008h-16.225a2.914 2.914 0 0 1 -2.582 -4.2l.099 -.185l8.11 -13.538a2.914 2.914 0 0 1 2.491 -1.403zm.01 13.33l-.127 .007a1 1 0 0 0 0 1.986l.117 .007l.127 -.007a1 1 0 0 0 0 -1.986l-.117 -.007zm-.01 -7a1 1 0 0 0 -.993 .883l-.007 .117v4l.007 .117a1 1 0 0 0 1.986 0l.007 -.117v-4l-.007 -.117a1 1 0 0 0 -.993 -.883z" stroke-width="0" fill="currentColor" /></svg>
                                @Messages.Warning !
                            </b>
                        </p>


                    </div>
                </div>

            </div>
            <ul class="mb-0">
				@foreach (var message in pageWarnings)
				{
					<li>@(message)</li>
				}
			</ul>


        </div>
	}
    
    if (pageSuccesses != null && pageSuccesses.Count != 0)
	{
  
        <div class="alert alert-success alert-dismissible shadow fade show text-right alert-message " style="border:#013220 1.5px solid" role="alert">
            <div class="alert-heading">


                <div class="row">
                    <button type="button"
                            class="btn-close btn-close-black me-2 m-auto"
                            data-bs-dismiss="alert"
                            aria-label="&times;"
                          ></button>
             
                </div>

            </div>
            <ul class="mb-0">
				@foreach (var message in pageSuccesses)
				{
                    <li style="color:darkgreen">@(message)</li>
                }
			</ul>
     
        </div>
    }

    pageErrors = null;
    pageSuccesses = null;
    pageWarnings = null;
}
