<environment include="Development">
  @* Template helper js *@
    <script src="~/admin/vendor/js/helpers.dist.js" asp-append-version="true"></script>
  @* Template customizer js *@
    <script src="~/admin/vendor/js/template-customizer.dist.js" asp-append-version="true"></script>
  @* Config file contain global vars & default theme options, Set your preferred theme option in this file. *@
