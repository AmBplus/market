@using Framework.Resources
@inject Framework.Settings.AppSettings.ApplicationSettings applicationSettings

@{
    var toastSettings = applicationSettings.ToastSettings;

    // int delayStep = toastSettings.DelayStep;
    int delayStep = toastSettings.DelayStep;
    int delay = 0 - delayStep;

    var toastErrors = TempData[key: Infrastructure.Messages.MessageType.ToastError.ToString()] as System.Collections.Generic.IList<string>;
    TempData[key: Infrastructure.Messages.MessageType.ToastError.ToString()] = null;

    var toastWarnings = TempData[key: Infrastructure.Messages.MessageType.ToastWarning.ToString()] as System.Collections.Generic.IList<string>;
    TempData[key: Infrastructure.Messages.MessageType.ToastWarning.ToString()] = null;

    var toastSuccesses = TempData[key: Infrastructure.Messages.MessageType.ToastSuccess.ToString()] as System.Collections.Generic.IList<string>;
    TempData[key: Infrastructure.Messages.MessageType.ToastSuccess.ToString()] = null;

    var toastInfo = TempData[key: Infrastructure.Messages.MessageType.ToastInfo.ToString()] as System.Collections.Generic.IList<string>;
    TempData[key: Infrastructure.Messages.MessageType.ToastInfo.ToString()] = null;

    if(  (toastErrors == null) && (toastInfo == null) && (toastSuccesses == null)  && (toastWarnings == null) )
    {
        return;
    }
    var error = Messages.Error;
    var warning = Messages.Warning;

}

<script>
 
    window.addEventListener('load', () => {
        toastr.options = {
            closeButton: true,
            progressBar: true,
            preventDuplicates: true,
            newestOnTop: true,
            showEasing: 'swing',
            hideEasing: 'linear',
            showMethod: 'fadeIn',
            hideMethod: 'fadeOut',
            showDuration: 300,
            hideDuration: 1000,
            timeOut: 2000,
            extendedTimeOut: 1000,
            rtl: isRtl,
            messageClass: 'fw-bold',
 
        };

    @if (toastErrors != null)
    {
        foreach (var message in toastErrors)
        {
            delay += delayStep;

            <text>
                    setTimeout(() => {
                        toastr.error('@(message)', '@error');
                    }, @delay);
            </text>
            ;
        }
    }

    @if (toastWarnings != null)
    {
        foreach (var message in toastWarnings)
        {
            delay += delayStep;

            <text>
                    setTimeout(() => {
                        toastr.warning('@(message)', '@warning');
                    }, @delay);
            </text>
            ;
        }
    }

    @if (toastSuccesses != null)
    {
        foreach (var message in toastSuccesses)
        {
            delay += delayStep;

            <text>
                    setTimeout(() => {
                        toastr.success('@(message)');
                    }, @delay);
            </text>
            ;
        }
    }
    @if (toastInfo != null)
    {
        foreach (var message in toastInfo)
        {
            delay += delayStep;

            <text>
                    setTimeout(() => {
                        toastr.info('@(message)');
                    }, @delay);
            </text>
            ;
        }
    }



        });
</script>
