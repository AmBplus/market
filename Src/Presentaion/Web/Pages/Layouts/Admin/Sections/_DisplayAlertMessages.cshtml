@inject Framework.Settings.AppSettings.ApplicationSettings applicationSettings
<link href="~/admin/assets/styles/modal.css" rel="stylesheet" />
@{
    /// Version 3.0

    var toastSettings = applicationSettings.ToastSettings;
    int delayStep = toastSettings.DelayStep;
    int delay = toastSettings.InitialDelay - delayStep;

    var alertErrors = TempData[key: Infrastructure.Messages.MessageType.AlertError.ToString()] as System.Collections.Generic.IList<string>;
    var alertWarnings = TempData[key: Infrastructure.Messages.MessageType.AlertWarning.ToString()] as System.Collections.Generic.IList<string>;
    var alertSuccesses = TempData[key: Infrastructure.Messages.MessageType.AlertSuccess.ToString()] as System.Collections.Generic.IList<string>;

    if ((alertErrors == null || alertErrors.Count == 0) &&
        (alertWarnings == null || alertWarnings.Count == 0) &&
        (alertSuccesses == null || alertSuccesses.Count == 0))
    {
        return;
    }

    // Set Preview Value Null For Prevent Repeat
    TempData[key: Infrastructure.Messages.MessageType.AlertError.ToString()] = null;
    TempData[key: Infrastructure.Messages.MessageType.AlertWarning.ToString()] = null;
    TempData[key: Infrastructure.Messages.MessageType.AlertSuccess.ToString()] = null;
}

<div class="position-fixed top-50 start-50 translate-middle" style="z-index: 1000;">
    @if (alertErrors != null)
    {
        <div class="modal fade" id="statusErrorModal" tabindex="-1" role="dialog" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="text-center text-danger">
                @foreach (var message in alertErrors)
                {
                    <p>@message</p>
                }
            </div>
        </div>
    }

    @if (alertWarnings != null)
    {
        <div class="modal fade" id="statusWarningModal" tabindex="-1" role="dialog" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="text-center text-warning">
                @foreach (var message in alertWarnings)
                {
                    <p>@message</p>
                }
            </div>
        </div>
    }

    @if (alertSuccesses != null)
    {
        <div class="modal fade" id="statusSuccessModal" tabindex="-1" role="dialog" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="text-center text-green">
                @foreach (var message in alertSuccesses)
                {
                    <p>@message</p>
                }
            </div>
        </div>
    }
</div>

@{
    alertErrors = null;
    alertSuccesses = null;
    alertWarnings = null;
}

<script>
    window.addEventListener('load', (e) => {
        var timeout = 10000; // 10 seconds

        function showModal(modalId, icon, title) {
            if ($(modalId).length > 0) {
                var divContent = document.getElementById(modalId.replace('#', '')).innerHTML;
                Swal.fire({
                    html: divContent,
                    icon: icon,
                    title: title,
                    confirmButtonText: 'باشه',
                    showCancelButton: false,
                    showDenyButton: false,
                    confirmButtonColor: '#3085d6',
                    padding: '1em',
                    customClass: {
                        confirmButton: 'btn btn-instagram me-3 waves-effect waves-light',
                    },
                    backdrop: true,
                    timer: timeout
                });
            }
        }

        // نمایش مدال‌ها بر اساس نوع پیام
        showModal('#statusSuccessModal', 'success', '');
        showModal('#statusErrorModal', 'error', 'خطا!');
        showModal('#statusWarningModal', 'warning', 'هشدار!');
    });
</script>
