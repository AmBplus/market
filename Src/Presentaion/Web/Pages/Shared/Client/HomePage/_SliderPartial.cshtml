        <path fill="currentColor" d="M11.5 12L16.5 17L15 18.5L7.5 11L15 3.5L16.5 5L11.5 10V12Z" />
    </symbol>
    <!-- Thicker Right Arrow -->
    <symbol id="arrow-long-right-icon" viewBox="0 0 24 24">
        <path fill="currentColor" d="M12.5 12L7.5 17L9 18.5L16.5 11L9 3.5L7.5 5L12.5 10V12Z" />
